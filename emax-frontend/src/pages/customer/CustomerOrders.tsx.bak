import { useEffect, useState, useCallback, useMemo } from "react";
import { Link } from "react-router-dom";
import {
  FaShoppingBag,
  FaBox,
  FaSpinner,
  FaTimesCircle,
  FaSearch,
  FaChevronDown,
  FaExclamationTriangle,
  FaCheckCircle,
  FaTruck,
  FaClock,
  FaBan,
  FaBoxOpen,
  FaRedo,
} from "react-icons/fa";
import CustomerShell from "./CustomerShell";
import { orderService, type Order, type OrderItem } from "../../services/orderService";

// ── Types ──
type FilterTab = "ALL" | "PENDING" | "PROCESSING" | "SHIPPED" | "DELIVERED" | "CANCELLED";

interface CancelState {
  show: boolean;
  orderId: number | null;
  loading: boolean;
}

interface ToastState {
  show: boolean;
  message: string;
}

// ── Helpers ──
const formatDate = (dateStr: string): string => {
  const date = new Date(dateStr);
  return date.toLocaleDateString("en-KE", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
};

const getStatusBadgeClass = (status: string): string => {
  const s = status.toUpperCase();
  if (s === "PENDING") return "order-status-badge--pending";
  if (s === "PROCESSING") return "order-status-badge--processing";
  if (s === "SHIPPED") return "order-status-badge--shipped";
  if (s === "DELIVERED") return "order-status-badge--delivered";
  if (s === "CANCELLED") return "order-status-badge--cancelled";
  return "order-status-badge--pending";
};

const getStatusIcon = (status: string) => {
  const s = status.toUpperCase();
  if (s === "PENDING") return FaClock;
  if (s === "PROCESSING") return FaSpinner;
  if (s === "SHIPPED") return FaTruck;
  if (s === "DELIVERED") return FaCheckCircle;
  if (s === "CANCELLED") return FaBan;
  return FaClock;
};

const getPaymentBadgeClass = (status: string): string => {
  const s = status.toUpperCase();
  if (s === "PAID") return "order-payment-badge--paid";
  if (s === "PENDING") return "order-payment-badge--pending";
  if (s === "FAILED") return "order-payment-badge--failed";
  if (s === "REFUNDED") return "order-payment-badge--refunded";
  return "order-payment-badge--pending";
};

const canCancel = (status: string): boolean => {
  const s = status.toUpperCase();
  return s === "PENDING" || s === "PROCESSING";
};

// ── Component ──
const CustomerOrders = () => {
  const [orders, setOrders] = useState<Order[]>([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);
  const [activeFilter, setActiveFilter] = useState<FilterTab>("ALL");
  const [searchQuery, setSearchQuery] = useState("");
  const [expandedId, setExpandedId] = useState<number | null>(null);
  const [cancel, setCancel] = useState<CancelState>({ show: false, orderId: null, loading: false });
  const [toast, setToast] = useState<ToastState>({ show: false, message: "" });

  // ── Load Orders ──
  const loadOrders = useCallback(async () => {
    setLoading(true);
    setError(null);
    try {
      const response = await orderService.getMyOrders();
      setOrders(response.data || []);
    } catch (err: any) {
      setError(err?.message || "Failed to load orders. Please try again.");
      setOrders([]);
    } finally {
      setLoading(false);
    }
  }, []);

  useEffect(() => {
    loadOrders();
  }, [loadOrders]);

  // ── Stats ──
  const stats = useMemo(() => {
    const total = orders.length;
    const pending = orders.filter((o) => o.status === "PENDING").length;
    const delivered = orders.filter((o) => o.status === "DELIVERED").length;
    const cancelled = orders.filter((o) => o.status === "CANCELLED").length;
    return { total, pending, delivered, cancelled };
  }, [orders]);

  // ── Filtered & Searched Orders ──
  const filteredOrders = useMemo(() => {
    let filtered = orders;

    if (activeFilter !== "ALL") {
      filtered = filtered.filter((o) => o.status === activeFilter);
    }

    if (searchQuery.trim()) {
      const q = searchQuery.toLowerCase();
      filtered = filtered.filter(
        (o) =>
          o.orderNumber.toLowerCase().includes(q) ||
          o.items.some((item) => item.product.name.toLowerCase().includes(q))
      );
    }

    return filtered;
  }, [orders, activeFilter, searchQuery]);

  // ── Tab counts ──
  const tabCounts = useMemo(() => {
    const counts: Record<FilterTab, number> = {
      ALL: orders.length,
      PENDING: orders.filter((o) => o.status === "PENDING").length,
      PROCESSING: orders.filter((o) => o.status === "PROCESSING").length,
      SHIPPED: orders.filter((o) => o.status === "SHIPPED").length,
      DELIVERED: orders.filter((o) => o.status === "DELIVERED").length,
      CANCELLED: orders.filter((o) => o.status === "CANCELLED").length,
    };
    return counts;
  }, [orders]);

  // ── Cancel Order ──
  const handleCancelConfirm = async () => {
    if (!cancel.orderId) return;
    setCancel((prev) => ({ ...prev, loading: true }));
    try {
      await orderService.cancelOrder(cancel.orderId);
      // Update the order in local state
      setOrders((prev) =>
        prev.map((o) =>
          o.id === cancel.orderId ? { ...o, status: "CANCELLED" as const } : o
        )
      );
      setCancel({ show: false, orderId: null, loading: false });
      showToast("Order has been cancelled successfully.");
    } catch (err: any) {
      setCancel({ show: false, orderId: null, loading: false });
      showToast(err?.message || "Failed to cancel order.");
    }
  };

  const showToast = (message: string) => {
    setToast({ show: true, message });
    setTimeout(() => setToast({ show: false, message: "" }), 4000);
  };

  // ── Toggle expand ──
  const toggleExpand = (id: number) => {
    setExpandedId((prev) => (prev === id ? null : id));
  };

  // ── Filters ──
  const tabs: { key: FilterTab; label: string }[] = [
    { key: "ALL", label: "All Orders" },
    { key: "PENDING", label: "Pending" },
    { key: "PROCESSING", label: "Processing" },
    { key: "SHIPPED", label: "Shipped" },
    { key: "DELIVERED", label: "Delivered" },
    { key: "CANCELLED", label: "Cancelled" },
  ];

  // ── Render ──
  return (
    <CustomerShell title="My Orders">
      {/* Stats Summary Bar */}
      <div className="orders-stats-bar">
        <div className="orders-stat-card orders-stat-card--total fade-in">
          <div className="orders-stat-icon">
            <FaShoppingBag />
          </div>
          <p className="orders-stat-value">{stats.total}</p>
          <p className="orders-stat-label">Total Orders</p>
        </div>
        <div className="orders-stat-card orders-stat-card--pending fade-in-delay-1">
          <div className="orders-stat-icon">
            <FaClock />
          </div>
          <p className="orders-stat-value">{stats.pending}</p>
          <p className="orders-stat-label">Pending</p>
        </div>
        <div className="orders-stat-card orders-stat-card--delivered fade-in-delay-2">
          <div className="orders-stat-icon">
            <FaCheckCircle />
          </div>
          <p className="orders-stat-value">{stats.delivered}</p>
          <p className="orders-stat-label">Delivered</p>
        </div>
        <div className="orders-stat-card orders-stat-card--cancelled fade-in-delay-3">
          <div className="orders-stat-icon">
            <FaBan />
          </div>
          <p className="orders-stat-value">{stats.cancelled}</p>
          <p className="orders-stat-label">Cancelled</p>
        </div>
      </div>

      {/* Filter & Search Bar */}
      <div className="orders-filter-bar fade-in">
        <div className="orders-tabs">
          {tabs.map((tab) => (
            <button
              key={tab.key}
              className={`orders-tab-btn ${activeFilter === tab.key ? "active" : ""}`}
              onClick={() => setActiveFilter(tab.key)}
            >
              {tab.label}
              <span className="orders-tab-count">{tabCounts[tab.key]}</span>
            </button>
          ))}
        </div>

        <div className="orders-search-wrapper">
          <FaSearch className="orders-search-icon" />
          <input
            type="text"
            className="orders-search-input"
            placeholder="Search by order # or product..."
            value={searchQuery}
            onChange={(e) => setSearchQuery(e.target.value)}
          />
        </div>
      </div>

      {/* ── Loading State ── */}
      {loading && (
        <div className="orders-skeleton fade-in">
          {[1, 2, 3].map((i) => (
            <div key={i} className="order-skeleton-card" style={{ animationDelay: `${i * 0.1}s` }}>
              <div className="order-skeleton-header">
                <div className="order-skeleton-line" style={{ width: "180px" }} />
                <div className="order-skeleton-line" style={{ width: "100px" }} />
              </div>
              <div className="order-skeleton-items">
                {[1, 2].map((j) => (
                  <div key={j} className="order-skeleton-item">
                    <div className="order-skeleton-thumb" />
                    <div className="order-skeleton-text">
                      <div className="order-skeleton-line" style={{ width: "70%", marginBottom: 8 }} />
                      <div className="order-skeleton-line" style={{ width: "40%" }} />
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      )}

      {/* ── Error State ── */}
      {!loading && error && (
        <div className="orders-error fade-in">
          <FaTimesCircle className="orders-error-icon" />
          <h3>Oops! Something went wrong</h3>
          <p>{error}</p>
          <button className="orders-retry-btn" onClick={loadOrders}>
            <FaRedo style={{ marginRight: 8 }} />
            Try Again
          </button>
        </div>
      )}

      {/* ── Empty State ── */}
      {!loading && !error && orders.length === 0 && (
        <div className="orders-empty fade-in">
          <FaBoxOpen className="orders-empty-icon" />
          <h3>No orders yet</h3>
          <p>You haven't placed any orders yet. Start exploring our products and find something you love!</p>
          <Link to="/products" className="action-btn action-btn--primary">
            <FaShoppingBag />
            Start Shopping
          </Link>
        </div>
      )}

      {/* ── No Results After Filter/Search ── */}
      {!loading && !error && orders.length > 0 && filteredOrders.length === 0 && (
        <div className="orders-no-results fade-in">
          <p>No orders match your search or filter criteria.</p>
        </div>
      )}

      {/* ── Order Cards ── */}
      {!loading && !error && filteredOrders.length > 0 && (
        <div className="orders-list">
          {filteredOrders.map((order, idx) => {
            const StatusIcon = getStatusIcon(order.status);
            const isExpanded = expandedId === order.id;

            return (
              <div
                key={order.id}
                className="order-card"
                style={{ animationDelay: `${idx * 0.08}s` }}
              >
                {/* Card Header */}
                <div className="order-card-header" onClick={() => toggleExpand(order.id)}>
                  <div className="order-card-header-left">
                    <div>
                      <p className="order-card-number">
                        <FaShoppingBag style={{ marginRight: 8, color: "#6366f1", fontSize: 13 }} />
                        {order.orderNumber}
                      </p>
                      <p className="order-card-date">
                        <FaClock style={{ fontSize: 11 }} />
                        {formatDate(order.createdAt)} · {order.items.length} item{order.items.length > 1 ? "s" : ""}
                      </p>
                    </div>
                  </div>
                  <div className="order-card-header-right">
                    <span className={`order-status-badge ${getStatusBadgeClass(order.status)}`}>
                      <StatusIcon style={{ fontSize: 11 }} />
                      {order.status}
                    </span>
                    <span className={`order-payment-badge ${getPaymentBadgeClass(order.paymentStatus)}`}>
                      {order.paymentStatus}
                    </span>
                    <FaChevronDown
                      className={`order-card-expand-icon ${isExpanded ? "expanded" : ""}`}
                    />
                  </div>
                </div>

                {/* Card Body (Items) */}
                <div className={`order-card-body ${isExpanded ? "open" : ""}`}>
                  {order.items.map((item: OrderItem) => (
                    <div key={item.id} className="order-item-row">
                      {item.product.thumbnail ? (
                        <img
                          src={item.product.thumbnail}
                          alt={item.product.name}
                          className="order-item-thumb"
                          onError={(e) => {
                            (e.target as HTMLImageElement).style.display = "none";
                            (e.target as HTMLImageElement).nextElementSibling?.classList.remove("hidden");
                          }}
                        />
                      ) : null}
                      <div className="order-item-thumb-placeholder" style={{ display: item.product.thumbnail ? "none" : "flex" }}>
                        <FaBox />
                      </div>
                      <div className="order-item-details">
                        <p className="order-item-name">
                          <Link to={`/products/${item.product.slug}`} style={{ color: "inherit", textDecoration: "none" }}>
                            {item.product.name}
                          </Link>
                        </p>
                        <p className="order-item-meta">
                          Qty: {item.quantity} × KES {item.price.toLocaleString()}
                        </p>
                      </div>
                      <p className="order-item-price">
                        KES {(item.quantity * item.price).toLocaleString()}
                      </p>
                    </div>
                  ))}
                </div>

                {/* Card Footer */}
                <div className="order-card-footer">
                  <div className="order-card-total">
                    <span>Total Amount</span>
                    <strong>KES {order.totalAmount.toLocaleString()}</strong>
                  </div>
                  <div className="order-card-actions">
                    {canCancel(order.status) && (
                      <button
                        className="order-action-btn order-action-btn--danger"
                        onClick={() => setCancel({ show: true, orderId: order.id, loading: false })}
                      >
                        <FaBan />
                        Cancel
                      </button>
                    )}
                    <Link
                      to={`/products/${order.items[0]?.product?.slug || ""}`}
                      className="order-action-btn order-action-btn--outline"
                    >
                      <FaShoppingBag />
                      Reorder
                    </Link>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      )}

      {/* ── Cancel Confirmation Modal ── */}
      {cancel.show && (
        <div className="orders-modal-overlay" onClick={() => setCancel({ show: false, orderId: null, loading: false })}>
          <div className="orders-modal" onClick={(e) => e.stopPropagation()}>
            <div className="orders-modal-icon">
              <FaExclamationTriangle />
            </div>
            <h3>Cancel Order</h3>
            <p>
              Are you sure you want to cancel this order? This action cannot be undone.
            </p>
            <div className="orders-modal-actions">
              <button
                className="orders-modal-btn orders-modal-btn--cancel"
                onClick={() => setCancel({ show: false, orderId: null, loading: false })}
                disabled={cancel.loading}
              >
                Keep Order
              </button>
              <button
                className="orders-modal-btn orders-modal-btn--confirm"
                onClick={handleCancelConfirm}
                disabled={cancel.loading}
              >
                {cancel.loading ? "Cancelling..." : "Yes, Cancel"}
              </button>
            </div>
          </div>
        </div>
      )}

      {/* ── Toast Notification ── */}
      {toast.show && (
        <div className="orders-toast">
          <FaCheckCircle className="orders-toast-icon" />
          <p>{toast.message}</p>
        </div>
      )}
    </CustomerShell>
  );
};

export default CustomerOrders;

